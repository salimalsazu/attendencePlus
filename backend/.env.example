# JWT secret — use a long random string in production (openssl rand -hex 32)
JWT_SECRET=change_me_to_a_long_random_secret

# PostgreSQL password — use a strong password in production
POSTGRES_PASSWORD=change_me_strong_password

# ZKTeco device on your office LAN (or reachable via WireGuard)
ZK_IP=192.168.10.3
ZK_PORT=4370
ZK_TIMEOUT=10000

# Public URL of your VPS backend — used by the browser to call the API
# Replace with your VPS IP or domain (no trailing slash)
NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP:3000
