# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret

# PostgreSQL password
POSTGRES_PASSWORD=change_me_strong_password

# ZKTeco device — use WireGuard tunnel IP + portproxy
ZK_IP=10.8.0.2
ZK_PORT=4370
ZK_TIMEOUT=10000

# Public URL of your VPS backend (used by the browser)
# Replace with your actual VPS IP or domain
NEXT_PUBLIC_API_URL=http://89.167.82.188:4000
